{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src/**/*", "./prisma"],
  "exclude": ["node_modules", "dist"]
}
